{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://0.0.0.0:13000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "USER_DB": "Data Source={0}User.db"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://0.0.0.0:13001;http://0.0.0.0:13000",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "USER_DB": "Data Source={0}User.db"
      }
    }
  }
}