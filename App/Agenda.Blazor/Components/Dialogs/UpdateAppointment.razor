<MudDialog>
    <DialogContent>
        <MudTextField Class="mt-5" Label="Id" Value="Id" ReadOnly="true" />
        <MudTextField Class="mt-3" Label="Comment" @bind-Value="Comment" MaxLength="50" />
        <MudSelect Class="mt-3" Label="Type" @bind-Value="Type">
            @foreach (AppointmentType type in Enum.GetValues<AppointmentType>())
            {
                <MudSelectItem Value="@type">@type</MudSelectItem>
            }
        </MudSelect>
        <MudDatePicker Class="mt-3" Label="Date" @bind-Date="Date" />
        <MudTimePicker Class="mt-3" Label="Time" @bind-Time="Time" AmPm="false" />
    </DialogContent>

    <DialogActions>
        <MudGrid Class="d-flex justify-center ml-0 mt-4 mb-10">
            <MudButton Class="px-8 mr-4" Variant="Variant.Outlined" OnClick="Update">Update</MudButton>
            <MudButton Class="px-8" Variant="Variant.Outlined" OnClick="Cancel">Cancel</MudButton>
        </MudGrid>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance DialogInstance { get; set; }
    [Parameter]
    public int Id { get; set; }
    [Parameter]
    public string Comment { get; set; }
    [Parameter]
    public AppointmentType Type { get; set; }
    [Parameter]
    public DateTime? Date { get; set; }
    [Parameter]
    public DateTime Created { get; set; }

    public TimeSpan? Time
    {
        get { return Date.Value.TimeOfDay; }
        set { Date = Date.Value.Date + value.Value; }
    }

    private void Update()
    {
        DialogInstance.Close(DialogResult.Ok(new Appointment(Id, Comment, Type, Date.Value, Created, null)));
    }

    private void Cancel()
    {
        DialogInstance.Cancel();
    }
}