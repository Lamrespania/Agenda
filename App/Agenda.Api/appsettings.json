{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Agenda": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "../logs/Agenda.Api-.log",
          "rollingInterval": "Day",
          "retainedFileTimeLimit": "1.00:00:00",
          "retainedFileCountLimit": null
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://0.0.0.0:11000"
      }
    }
  }
}