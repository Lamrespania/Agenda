<Window x:Class="Agenda.WPF.Insert"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agenda.WPF"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        mc:Ignorable="d"
        Title="Insert" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Background="LightGray">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Width="250" Margin="10 40">
            <TextBlock Text="Comment" Margin="0 0 0 5" FontWeight="Bold" />
            <TextBox Height="30" Margin="0 0 0 15" Padding="5 0 0 0" VerticalContentAlignment="Center" MaxLength="50"
                     Text="{Binding Comment}" />

            <TextBlock Text="Type" Margin="0 0 0 5" FontWeight="Bold" />
            <ComboBox Height="30" Margin="0 0 0 15" Padding="5 0 0 0" VerticalContentAlignment="Center"
                      ItemsSource="{Binding Types}" SelectedItem="{Binding TypeSelected}" />

            <TextBlock Text="Date" Margin="0 0 0 5" FontWeight="Bold" />
            <xctk:DateTimePicker Width="250" Height="30" Margin="0 0 0 15" VerticalContentAlignment="Center" TextAlignment="Left"
                                 Value="{Binding Date}" Format="Custom" FormatString="{StaticResource DateTimeFormat}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Insert" Width="100" Height="30" Margin="0 0 5 0" Background="WhiteSmoke" Command="{Binding InsertCommand}" />
                <Button Content="Cancel" Width="100" Height="30" Background="WhiteSmoke" Command="{Binding CancelCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>