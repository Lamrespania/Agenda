<Window x:Class="Agenda.WPF.CustomDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agenda.WPF"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtMessage" Width="300" Height="100" Background="WhiteSmoke" TextWrapping="Wrap" FontSize="12"
                   Margin="5 10 5 7" Padding="5" IsEnabled="False" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnOk" Content="OK" Background="WhiteSmoke" Width="80" Height="30" Margin="0 0 10 5" Click="btnOk_Click" />
            <Button x:Name="btnCancel" Content="Cancel" Background="WhiteSmoke" Width="80" Height="30" Margin="0 0 0 5" Click="btnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>