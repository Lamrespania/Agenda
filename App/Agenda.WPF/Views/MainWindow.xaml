<Window x:Class="Agenda.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agenda.WPF.Converters"
        mc:Ignorable="d"
        Title="Main" Height="450" Width="800" WindowState="Maximized">

    <Window.Resources>
        <local:DateExpiredConverter x:Key="DateExpired" />
        <local:VisibilityBoolOppositeConverter x:Key="VisibilityBoolOpposite" />

        <Style TargetType="DataGridRow" x:Key="BackgroundColorRowStyle">
            <Setter Property="Background" Value="White" />

            <Style.Triggers>
                <DataTrigger Binding="{Binding Date, Converter={StaticResource DateExpired}}" Value="true">
                    <Setter Property="Background" Value="PaleGoldenrod" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DataGridStyle" TargetType="DataGrid">
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserSortColumns" Value="False" />
            <Setter Property="IsEnabled" Value="{Binding Enabled}" />
        </Style>

        <Style x:Key="CenteredText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="5 0 0 0" />
        </Style>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0 3" />
            <Setter Property="Height" Value="35" />
            <Setter Property="Background" Value="WhiteSmoke" />
        </Style>
    </Window.Resources>

    <Grid Background="LightGray">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TabControl SelectedItem="{Binding TabSelected,Mode=OneWayToSource}">
            <TabItem Header="All" Width="75">
                <Grid>
                    <DataGrid Style="{StaticResource DataGridStyle}" RowStyle="{StaticResource BackgroundColorRowStyle}"
                              ItemsSource="{Binding AppointmentsAll}" SelectedItem="{Binding AppointmentsAllSelected}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="0.05*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="0.40*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.1*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Created" Binding="{Binding Created, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Modified" Binding="{Binding Modified, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Current" Width="75">
                <Grid>
                    <DataGrid Style="{StaticResource DataGridStyle}"
                              ItemsSource="{Binding AppointmentsCurrent}" SelectedItem="{Binding AppointmentsCurrentSelected}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="0.05*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="0.40*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.1*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Created" Binding="{Binding Created, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Modified" Binding="{Binding Modified, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Expired" Width="75">
                <Grid>
                    <DataGrid Style="{StaticResource DataGridStyle}"
                              ItemsSource="{Binding AppointmentsExpired}" SelectedItem="{Binding AppointmentsExpiredSelected}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="0.05*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="0.40*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="0.1*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Created" Binding="{Binding Created, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                            <DataGridTextColumn Header="Modified" Binding="{Binding Modified, StringFormat={StaticResource DateTimeFormat}}" Width="0.15*" ElementStyle="{StaticResource CenteredText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center" Width="140" Margin="5">
                <Button Style="{StaticResource ButtonStyle}" Content="Get" Command="{Binding GetCommand}" IsEnabled="{Binding Enabled}" />
                <Button Style="{StaticResource ButtonStyle}" Content="Delete" Command="{Binding DeleteCommand}" IsEnabled="{Binding EnabledDelete}" />
                <Button Style="{StaticResource ButtonStyle}" Content="Insert" Command="{Binding InsertCommand}" IsEnabled="{Binding Enabled}" />
                <Button Style="{StaticResource ButtonStyle}" Content="Update" Command="{Binding UpdateCommand}" IsEnabled="{Binding EnabledUpdate}" />
                <Button Style="{StaticResource ButtonStyle}" Content="Exit" Command="{Binding ExitCommand}" IsEnabled="{Binding Enabled}" />
            </StackPanel>

            <StackPanel Grid.Row="1" HorizontalAlignment="Center" Width="140" Margin="5">
                <Button Style="{StaticResource ButtonStyle}" Content="Cancel" Command="{Binding CancelCommand}"
                        Visibility="{Binding Enabled, Converter={StaticResource VisibilityBoolOpposite}}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>