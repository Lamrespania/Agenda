<Window x:Class="Agenda.WPF.Login"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Agenda.WPF"
        mc:Ignorable="d"
        Title="Login" WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        SizeToContent="WidthAndHeight" Background="LightGray">

    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Width="250" Margin="10 40">
        <TextBlock Text="Username" Margin="0 0 0 5" FontWeight="Bold" />
        <TextBox Height="30" Margin="0 0 0 15" Padding="5 0 0 0" VerticalContentAlignment="Center" MaxLength="30"
                 Text="{Binding Username}" IsEnabled="{Binding Enabled}" />

        <TextBlock Text="Password" Margin="0 0 0 5" FontWeight="Bold" />
        <PasswordBox x:Name="LoginPassword" Height="30" Margin="0 0 0 20" Padding="5 0 0 0" VerticalContentAlignment="Center" MaxLength="30"
                     PasswordChanged="LoginPasswordChanged" IsEnabled="{Binding Enabled}" />

        <Button Content="Login" Height="30" Background="WhiteSmoke"
                Command="{Binding LoginCommand}" IsEnabled="{Binding Enabled}" />
    </StackPanel>
</Window>